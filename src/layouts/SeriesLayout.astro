---
/**
 * SeriesLayout.astro
 * Replaces _layouts/series.html
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import '@styles/blog.css';

interface Props {
  title: string;
  ads?: boolean;
}
const { title } = Astro.props;
---
<BaseLayout title={title}>
  <div class="bg-dark">
    <div class="pt-4 pb-5 text-white">
      <div class="container">
        <h2>{title}</h2>
        <div class="p-5"></div>
      </div>
    </div>

    <div class="container post-content-container">
      <div class="row">
        <div class="col-md-12">
          <div id="post" class="card">
            <div class="card-body">
              <div class="page-content">
                <slot />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <br />
  </div>
</BaseLayout>
