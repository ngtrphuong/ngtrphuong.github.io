---
import Navbar from '@components/Navbar.astro';
import '@styles/styles.css';
import '@fortawesome/fontawesome-free/css/all.min.css';
import 'bootstrap/dist/css/bootstrap.min.css';
import ViewTransitions from '@components/ViewTransitions.astro';

/**
 * BaseLayout.astro
 * Replaces _layouts/default.html + _includes/head.html + _includes/navbar.html
 */
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  accentColor?: string;
  manifest?: string;
  ads?: boolean;
  feedUrl?: string;
  canonicalUrl?: string;
}

const {
  title,
  description,
  ogImage,
  accentColor,
  manifest,
  feedUrl,
  canonicalUrl,
} = Astro.props;

const BASE = import.meta.env.BASE_URL;

const pageTitle = title ? title : 'Blog | ngtrphuong';
const resolvedCanonical = canonicalUrl || Astro.url.href;
---
<!DOCTYPE html>
<html lang="en-us">
<head>
  <meta charset="UTF-8" />
  <title>{pageTitle}</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {description && <meta name="description" content={description} />}

  <link rel="icon" href={`${BASE}images/favicon.ico`} />
  <link rel="canonical" href={resolvedCanonical} />

  {/* OpenGraph */}
  <meta property="og:title" content={pageTitle} />
  {description && <meta property="og:description" content={description} />}
  <meta property="og:type" content="website" />
  <meta property="og:url" content={resolvedCanonical} />
  {ogImage && <meta property="og:image" content={ogImage} />}

  {/* Twitter Card */}
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:site" content="@ngtrphuong" />


  {manifest && <link rel="manifest" href={`${BASE}${manifest}`} />}

  {/* RSS Feed */}
  {feedUrl && <link rel="alternate" type="application/rss+xml" title="ngtrphuong Blog" href={feedUrl} />}
  {!feedUrl && <link rel="alternate" type="application/rss+xml" title="ngtrphuong Blog" href={`${BASE}feed.xml`} />}

  {accentColor && <style define:vars={{ accentColor }}>{`:root { --post-accent: ${accentColor}; }`}</style>}

  <ViewTransitions />
  
  <slot name="head" />
</head>
<body class="bg-dark">
  <Navbar />
  <slot />
</body>
</html>
